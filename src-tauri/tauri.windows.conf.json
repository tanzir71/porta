{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Porta",
        "width": 480,
        "height": 680,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
