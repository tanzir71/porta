{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Porta",
  "version": "1.2.0",
  "identifier": "com.porta.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Porta",
        "width": 480,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/cloudflared"]
  }
}
